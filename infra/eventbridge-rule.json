{
  "Name": "catanrl-drift-monitor",
  "ScheduleExpression": "rate(6 hours)",
  "State": "ENABLED",
  "Description": "Trigger drift monitor Lambda every 6 hours",
  "Targets": [
    {
      "Arn": "arn:aws:lambda:us-east-1:ACCOUNT_ID:function:catanrl-drift-monitor",
      "Id": "drift-monitor-target"
    }
  ]
}
